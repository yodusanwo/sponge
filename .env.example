# PostgreSQL (e.g. Neon) — required for admin-saved content
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Admin login (choose one style)
# Single user:
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="use-a-long-random-secret"

# Or multiple users: "email1:pass1;email2:pass2"
# ADMIN_CREDENTIALS="admin@example.com:secret1;other@example.com:secret2"

# Vercel Blob — required only for image uploads from /admin (optional; can paste image URLs instead)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
